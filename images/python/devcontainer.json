{
  "name": "Python CLI Dev Environment",
  "build": {
    "dockerfile": "../../docker/Dockerfile",
    "target": "python",
    "context": "../.."
  },
  "remoteUser": "developer",
  "remoteEnv": {
    "UV_PROJECT_ENVIRONMENT": "/home/developer/.venv"
  },
  "workspaceFolder": "/home/developer/app",
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/developer/app,type=bind",
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.azure,target=/home/developer/.azure,type=bind"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.defaultInterpreterPath": "/home/developer/.venv/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-azurecli"
      ]
    }
  }
}
